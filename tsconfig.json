{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "*"
      ]
    },
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "modules/**/*.ts",
    "modules/**/*.tsx",
    "shared/**/*.ts",
    "shared/**/*.tsx",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next/standalone",
    "bmad-method",
    "archive",
    "agents-disabled",
    "e2e",
    "components-disabled",
    "scripts-disabled",
    "lib-disabled",
    "app-complex",
    "instrumentation-disabled",
    "sentry-disabled",
    "scripts",
    "playwright-report",
    "test-results"
  ]
}
