{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": "..",
    "baseUrl": "..",
    "outDir": "../.scripts-out"
  },
  "include": [
    "./**/*.ts",
    "../lib/**/*.ts"
  ]
}
