  "scripts": {
    "// --- CHECKS ---": "",
    "// --- LEGACY/GRANULAR TESTS (Kept for reference) ---": "",
    "// --- TESTS: ALL ---": "",
    "// --- TESTS: LAYERS ---": "",
    "// --- TESTS: PHASES ---": "",
    "// --- UTILS ---": "",
    "audit:all": "run-p audit:security audit:deps",
    "audit:deps": "npm outdated",
    "audit:security": "npm audit",
    "build": "npm run build-posts && next build --webpack",
    "build-posts": "node scripts/process-posts.js",
    "build:analyze": "ANALYZE=true npm run build",
    "check:all": "run-s lint typecheck format:check",
    "cms:migrate:expeditions": "sanity exec scripts/migrate-expeditions-to-sanity.ts --with-user-token",
    "db:migrate:whoop": "node --env-file=.env.local scripts/migrate-whoop-neon.mjs",
    "dev": "next dev --webpack",
    "eval:core": "jest tests/unit/internal-api-auth.test.ts tests/unit/training-ingest-auth.test.ts tests/unit/content-repository.test.ts tests/unit/training-snapshot-service.test.ts tests/unit/training-metrics.test.ts tests/unit/training-dashboard.test.ts tests/unit/training-artifact-service.test.ts tests/unit/sync-controller.test.ts tests/unit/monitoring-controller.test.ts tests/unit/analytics-controller.test.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint app lib modules shared proxy.ts next.config.mjs --ext js,jsx,ts,tsx",
    "lint:fix": "eslint app lib modules shared proxy.ts next.config.mjs --ext js,jsx,ts,tsx --fix",
    "start": "next start",
    "test": "playwright test",
    "test:all": "run-s test:unit test:e2e",
    "test:e2e": "playwright test tests/e2e",
    "test:fast": "run-s test:unit",
    "test:mobile": "playwright test tests/e2e/mobile-*.spec.ts",
    "test:ui": "playwright test --ui",
    "test:unit": "jest tests/unit",
    "typecheck": "tsc --noEmit"
  },
  "version": "1.0.0"
